# --- Xenara server configuration ---

# Port (Render sets this automatically)
PORT=3000

# Secret used to sign login sessions. CHANGE THIS in production!
JWT_SECRET=change-me-to-a-long-random-string

# Where the SQLite database lives (set to your Render persistent disk mount path)
# DATA_DIR=/var/data

# --- Connect a real language model (optional but recommended) ---
# Any OpenAI-compatible endpoint. Leave blank to use the built-in Xenara Core engine.
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Local Ollama:http://localhost:11434/v1
# XENARA_MODEL_URL=
# XENARA_MODEL_KEY=
# XENARA_MODEL_NAME=gpt-4o-mini

# --- Web research (gather live data from the open web) ---
# Enabled by default using keyless DuckDuckGo. Set to "off" to disable entirely.
# XENARA_WEB=on
# Optional higher-quality providers (auto-detected if a key is present):
#   Tavily:  https://tavily.com   -> set TAVILY_API_KEY
#   Brave:   https://brave.com/search/api -> set BRAVE_API_KEY
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# Force a provider: duckduckgo | tavily | brave
# XENARA_SEARCH_PROVIDER=duckduckgo
# Page-fetch timeout in ms
# XENARA_FETCH_TIMEOUT_MS=9000

# --- Ownership & continual learning ---
# This instance is single-owner: the FIRST account created becomes the owner
# and registration then closes automatically. The owner gets a personal API
# key (xen_live_...) to use Xenara in their own apps.
#
# Continual learning: every question trains the neural model a little more.
# Set to "off" to disable online learning.
# XENARA_LEARN=on
